{
  "manifest_version": 3,
  "name": "Focus Pause",
  "version": "0.1",
  "description": "Pause before time-wasting sites and track your usage",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
  {
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }
]
,
  "action": {
  "default_popup": "popup.html",
  "default_icon": {
    "16": "images/icon16.png",
    "32": "images/icon32.png"
  }
},
  "icons": {
  "16": "images/icon16.png",
  "32": "images/icon32.png",
  "48": "images/icon48.png",
  "128": "images/icon128.png"
},
 "options_page": "options.html"

}
